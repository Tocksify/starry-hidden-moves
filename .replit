modules = ["nodejs-20", "web", "python-base-3.13"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PartyKit dev server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "PartyKit dev server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx partykit dev"

[[ports]]
localPort = 1999
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 9229
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
run = ["node", ".output/server/index.mjs"]
build = ["bun", "run", "build"]
